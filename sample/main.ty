namespace main

struct Popcount {
  ar: [Int32],
}

impl Popcount {
  fn check(self, even: Int32) -> Bool {
    for x in self.ar {
      if even % x == 0 {
        return true;
      }
    }
    return false;
  }
}

fn main() -> Int32 {
  let p: Popcount = Popcount {
    ar: [2, 4, 8, 16, 32],
  }
  if p.check(5) {
    return 0;
  } else {
    return 3;
  }
}
