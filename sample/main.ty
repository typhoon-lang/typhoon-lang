namespace main

struct Popcount {
  ar: [Int32],
}

impl Popcount {
  fn check(self, even: Int32) -> Int32 {
    let mut count = 0;
    for x in self.ar {
      if (x & even) == x {
        count = count + 1;
      }
    }
    return count;
  }
}

fn main() -> Int32 {
  let p: Popcount = Popcount {
    ar: [1, 2, 4, 8, 16, 32],
  }
  return p.check(15);
}
